{
  "manifest_version": 3,
  "name": "Pekacek — Reading Companion",
  "version": "2.0.0",
  "description": "PKA osobni znalostni asistent — sidebar pro cteni, souhrny, protimyslenky a wiki ingest.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "bookmarks",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:3888/*",
    "http://localhost:3777/*",
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Pekacek — klik otevre sidebar, pravy klik > Moznosti"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icons/pekacek-48.png",
    "128": "icons/pekacek-128.png"
  }
}
