{
  "manifest_version": 3,
  "name": "Pekáček Bookmarks Bridge",
  "version": "1.0",
  "description": "Bridge between Chrome bookmarks and Pekáček MCP server",
  "permissions": ["bookmarks", "alarms"],
  "host_permissions": ["http://localhost:3777/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
